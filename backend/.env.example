# Environment
NODE_ENV=production

# Server Configuration
PORT=5000

# Client URL (separate multiple URLs with commas for CORS)
CLIENT_URL=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Database
DB_URL=mongodb+srv://username:password@cluster.mongodb.net/ai-resume-analyzer

# JWT Authentication (Use a strong random string in production)
JWT_SECRET=your-secure-jwt-secret-here-min-32-characters-strong

# Cloudinary Configuration (For file uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Google Gemini API (For AI analysis)
GEMINI_API_KEY=your-gemini-api-key

# Email Configuration (Gmail App Password)
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-gmail-app-password
